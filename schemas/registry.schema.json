{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/xapi-labs/skill-market/schemas/registry.schema.json",
  "title": "xAPI Skill Market Registry",
  "type": "object",
  "required": ["schemaVersion", "skills"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "generatedAt": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "skills": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["slug", "path"],
        "additionalProperties": true,
        "properties": {
          "slug": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]{1,62}[a-z0-9]$"
          },
          "name": {
            "type": "string"
          },
          "version": {
            "type": "string"
          },
          "path": {
            "type": "string",
            "pattern": "^skills/[a-z0-9][a-z0-9-]{1,62}[a-z0-9]$"
          },
          "normalizedSha256": {
            "type": ["string", "null"],
            "pattern": "^[a-f0-9]{64}$"
          },
          "publishedAt": {
            "type": ["string", "null"],
            "format": "date-time"
          }
        }
      }
    }
  }
}
